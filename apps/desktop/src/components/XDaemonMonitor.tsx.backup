/**
 * X-Daemon Status Monitor Component
 *
 * Real-time monitoring and control dashboard for X-Daemon with:
 * - Live daemon status and lifecycle controls
 * - Chrome Pool health monitoring
 * - Task Queue statistics and visualization
 * - Recent operations history with auto-scroll
 * - Auto-refresh with polling at 2-second intervals
 *
 * Uses Tauri's call_worker_api command to communicate with the backend
 * worker running on localhost:8765
 */

import React, { useState, useEffect, useCallback, useRef } from "react";
import { invoke } from "@tauri-apps/api/core";
import {
  DaemonStatus,
  QueueStatus,
  OperationLog,
  WorkerApiResponse,
} from "../types/daemon";

/**
 * Component for displaying X-Daemon status and controls
 */
const XDaemonMonitor: React.FC = () => {
  // State management
  const [daemonStatus, setDaemonStatus] = useState<DaemonStatus | null>(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);
  const [autoRefresh, setAutoRefresh] = useState(true);
  const [isRefreshing, setIsRefreshing] = useState(false);
  const [operationLogs, setOperationLogs] = useState<OperationLog[]>([]);
  const [actionInProgress, setActionInProgress] = useState<string | null>(null);
  const [lastRefreshTime, setLastRefreshTime] = useState<Date | null>(null);
  const operationsEndRef = useRef<HTMLDivElement>(null);
  const refreshIntervalRef = useRef<NodeJS.Timeout | null>(null);
  const retryCountRef = useRef(0);

  /**
   * Format seconds into human-readable uptime string
   * e.g., "2h 15m 30s"
   */
  const formatUptime = (seconds: number): string => {
    const hours = Math.floor(seconds / 3600);
    const minutes = Math.floor((seconds % 3600) / 60);
    const secs = seconds % 60;

    const parts = [];
    if (hours > 0) parts.push(`${hours}h`);
    if (minutes > 0) parts.push(`${minutes}m`);
    if (secs > 0 || parts.length === 0) parts.push(`${secs}s`);

    return parts.join(" ");
  };

  /**
   * Format ISO timestamp to readable format
   * e.g., "14:30:45"
   */
  const formatTime = (timestamp: string): string => {
    try {
      const date = new Date(timestamp);
      return date.toLocaleTimeString();
    } catch {
      return timestamp;
    }
  };

  /**
   * Calculate success rate percentage
   */
  const getSuccessRate = (): number => {
    const total = (daemonStatus?.total_operations || 0);
    if (total === 0) return 0;
    return Math.round(
      ((daemonStatus?.successful_operations || 0) / total) * 100
    );
  };

  /**
   * Fetch daemon status from worker API
   */
  const fetchDaemonStatus = useCallback(async () => {
    try {
      setIsRefreshing(true);
      setError(null);

      // Fetch daemon status
      const statusResponse = await invoke<WorkerApiResponse>(
        "call_worker_api",
        {
          method: "GET",
          endpoint: "/daemon/status",
        }
      );

      if (!statusResponse.data) {
        throw new Error("Invalid status response");
      }

      setDaemonStatus(statusResponse.data as DaemonStatus);

      // Extract recent operations from the response
      if (statusResponse.data.last_operation) {
        setOperationLogs((prev) => {
          const updated = [statusResponse.data.last_operation, ...prev];
          return updated.slice(0, 10); // Keep last 10 operations
        });
      }

      retryCountRef.current = 0;
      setLastRefreshTime(new Date());
    } catch (err) {
      const errorMessage =
        err instanceof Error ? err.message : "Failed to fetch daemon status";
      setError(errorMessage);

      // Retry logic: pause polling on error, retry after 5 seconds
      if (retryCountRef.current < 3) {
        retryCountRef.current++;
        setTimeout(() => {
          fetchDaemonStatus();
        }, 5000);
      } else {
        setAutoRefresh(false); // Stop auto-refresh after 3 retries
      }
    } finally {
      setIsRefreshing(false);
    }
  }, []);

  /**
   * Set up auto-refresh interval
   */
  useEffect(() => {
    if (!autoRefresh) {
      if (refreshIntervalRef.current) {
        clearInterval(refreshIntervalRef.current);
      }
      return;
    }

    // Fetch immediately on mount or when auto-refresh is enabled
    if (loading) {
      fetchDaemonStatus();
    }

    // Set up interval for polling
    refreshIntervalRef.current = setInterval(() => {
      fetchDaemonStatus();
    }, 2000); // Poll every 2 seconds

    // Cleanup on unmount or when autoRefresh changes
    return () => {
      if (refreshIntervalRef.current) {
        clearInterval(refreshIntervalRef.current);
      }
    };
  }, [autoRefresh, loading, fetchDaemonStatus]);

  // Set loading to false after first fetch attempt
  useEffect(() => {
    if (daemonStatus !== null || error !== null) {
      setLoading(false);
    }
  }, [daemonStatus, error]);

  /**
   * Auto-scroll to latest operation
   */
  useEffect(() => {
    if (operationsEndRef.current && operationLogs.length > 0) {
      operationsEndRef.current.scrollIntoView({ behavior: "smooth" });
    }
  }, [operationLogs]);

  /**
   * Execute daemon lifecycle action
   */
  const executeDaemonAction = async (action: "start" | "stop" | "restart") => {
    try {
      setActionInProgress(action);
      setError(null);

      // Confirm stop action
      if (action === "stop") {
        if (
          !window.confirm(
            "Are you sure you want to stop the daemon? Running tasks will be paused."
          )
        ) {
          setActionInProgress(null);
          return;
        }
      }

      const response = await invoke<WorkerApiResponse>("call_worker_api", {
        method: "POST",
        endpoint: `/daemon/${action}`,
        body: null,
      });

      // Refresh status immediately after action
      setTimeout(() => {
        fetchDaemonStatus();
      }, 500);

      // Show success message (in real app, use toast notification)
      console.log(`Daemon ${action} successful`);
    } catch (err) {
      const errorMessage =
        err instanceof Error ? err.message : `Failed to ${action} daemon`;
      setError(errorMessage);
    } finally {
      setActionInProgress(null);
    }
  };

  /**
   * Restart Chrome Pool
   */
  const restartChrome = async () => {
    try {
      setActionInProgress("restart-chrome");
      setError(null);

      await invoke<WorkerApiResponse>("call_worker_api", {
        method: "POST",
        endpoint: "/chrome/restart",
        body: null,
      });

      // Refresh status after restart
      setTimeout(() => {
        fetchDaemonStatus();
      }, 1000);

      console.log("Chrome restart initiated");
    } catch (err) {
      const errorMessage =
        err instanceof Error ? err.message : "Failed to restart Chrome";
      setError(errorMessage);
    } finally {
      setActionInProgress(null);
    }
  };

  /**
   * Manual refresh button handler
   */
  const handleManualRefresh = async () => {
    setAutoRefresh(false); // Temporarily stop auto-refresh
    await fetchDaemonStatus();
    setAutoRefresh(true); // Re-enable auto-refresh
  };

  // Render loading skeleton
  if (loading && !daemonStatus) {
    return (
      <div className="p-6 space-y-6">
        <div className="animate-pulse space-y-4">
          <div className="h-32 bg-gray-200 rounded-lg"></div>
          <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div className="h-32 bg-gray-200 rounded-lg"></div>
            <div className="h-32 bg-gray-200 rounded-lg"></div>
          </div>
        </div>
      </div>
    );
  }

  const queueStats = daemonStatus?.queue_stats || {
    pending: 0,
    running: 0,
    completed: 0,
    failed: 0,
  };
  const isRunning = daemonStatus?.daemon_status === "running";
  const isChromeHealthy = daemonStatus?.chrome_pool_healthy ?? false;
  const totalQueue =
    queueStats.pending + queueStats.running + queueStats.completed + queueStats.failed;
  const completedQueue = queueStats.completed + queueStats.failed;
  const queueProgress =
    totalQueue > 0 ? (completedQueue / totalQueue) * 100 : 0;

  return (
    <div className="p-6 space-y-6 bg-gradient-to-br from-gray-50 to-gray-100" style={{ minHeight: "calc(100vh - 73px)" }}>
      {/* Header */}
      <div className="flex justify-between items-center">
        <h1 className="text-3xl font-bold text-gray-900">X-Daemon Monitor</h1>
        <div className="flex items-center gap-4">
          {/* Refresh indicator */}
          {isRefreshing && (
            <div className="flex items-center gap-2 text-sm text-gray-600">
              <div className="animate-spin h-4 w-4 border-2 border-blue-500 border-t-transparent rounded-full"></div>
              Refreshing...
            </div>
          )}

          {/* Last refresh time */}
          {lastRefreshTime && (
            <span className="text-sm text-gray-500">
              Updated: {formatTime(lastRefreshTime.toISOString())}
            </span>
          )}

          {/* Manual refresh button */}
          <button
            onClick={handleManualRefresh}
            disabled={isRefreshing || actionInProgress !== null}
            className="px-3 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 disabled:bg-gray-400 transition-colors text-sm font-medium"
            aria-label="Refresh daemon status"
          >
            🔄 Refresh
          </button>
        </div>
      </div>

      {/* Error Alert */}
      {error && (
        <div className="bg-red-50 border-l-4 border-red-500 p-4 rounded-lg">
          <div className="flex items-start justify-between">
            <div>
              <p className="text-sm font-medium text-red-800">Error</p>
              <p className="text-sm text-red-700 mt-1">{error}</p>
            </div>
            <button
              onClick={() => setError(null)}
              className="text-red-700 hover:text-red-900"
            >
              ✕
            </button>
          </div>
        </div>
      )}

      {/* Main Grid Layout */}
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {/* Section A: Daemon Status Card */}
        <div className="lg:col-span-1 bg-white rounded-lg shadow-lg p-6 border-l-4 border-blue-500">
          <div className="space-y-4">
            {/* Status Header */}
            <div className="flex justify-between items-start">
              <div>
                <h2 className="text-xl font-bold text-gray-900 mb-2">
                  Daemon Status
                </h2>
                <div className="flex items-center gap-2">
                  <span
                    className={`inline-flex items-center gap-1 px-3 py-1 rounded-full text-sm font-semibold ${
                      isRunning
                        ? "bg-green-100 text-green-800"
                        : "bg-red-100 text-red-800"
                    }`}
                  >
                    <span className="text-lg">{isRunning ? "🟢" : "🔴"}</span>
                    {isRunning ? "Running" : "Stopped"}
                  </span>
                </div>
              </div>

              {/* Auto-refresh toggle */}
              <div className="flex items-center gap-2">
                <label className="text-sm font-medium text-gray-700">
                  Auto-refresh
                </label>
                <button
                  onClick={() => setAutoRefresh(!autoRefresh)}
                  className={`relative inline-flex h-6 w-11 items-center rounded-full transition-colors ${
                    autoRefresh ? "bg-green-500" : "bg-gray-300"
                  }`}
                  role="switch"
                  aria-checked={autoRefresh}
                >
                  <span
                    className={`inline-block h-4 w-4 transform rounded-full bg-white transition-transform ${
                      autoRefresh ? "translate-x-6" : "translate-x-1"
                    }`}
                  />
                </button>
              </div>
            </div>

            {/* Stats Grid */}
            <div className="grid grid-cols-2 gap-4 bg-gray-50 rounded-lg p-4">
              <div>
                <p className="text-sm text-gray-600">Uptime</p>
                <p className="text-lg font-bold text-gray-900">
                  {daemonStatus ? formatUptime(daemonStatus.uptime_seconds) : "—"}
                </p>
              </div>
              <div>
                <p className="text-sm text-gray-600">Total Operations</p>
                <p className="text-lg font-bold text-gray-900">
                  {daemonStatus?.total_operations || 0}
                </p>
              </div>
              <div>
                <p className="text-sm text-gray-600">Success Rate</p>
                <p className="text-lg font-bold text-green-600">
                  {getSuccessRate()}%
                </p>
              </div>
              <div>
                <p className="text-sm text-gray-600">Failed Ops</p>
                <p className="text-lg font-bold text-red-600">
                  {daemonStatus?.failed_operations || 0}
                </p>
              </div>
            </div>

            {/* Control Buttons */}
            <div className="flex gap-3 pt-4">
              <button
                onClick={() => executeDaemonAction("start")}
                disabled={isRunning || actionInProgress !== null}
                className="flex-1 px-4 py-2 bg-green-500 text-white rounded-lg hover:bg-green-600 disabled:bg-gray-400 transition-colors font-medium text-sm"
                aria-label="Start daemon"
              >
                {actionInProgress === "start" ? "⏳ Starting..." : "▶️ Start"}
              </button>
              <button
                onClick={() => executeDaemonAction("stop")}
                disabled={!isRunning || actionInProgress !== null}
                className="flex-1 px-4 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600 disabled:bg-gray-400 transition-colors font-medium text-sm"
                aria-label="Stop daemon"
              >
                {actionInProgress === "stop" ? "⏳ Stopping..." : "⏹️ Stop"}
              </button>
              <button
                onClick={() => executeDaemonAction("restart")}
                disabled={actionInProgress !== null}
                className="flex-1 px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 disabled:bg-gray-400 transition-colors font-medium text-sm"
                aria-label="Restart daemon"
              >
                {actionInProgress === "restart" ? "⏳ Restarting..." : "🔄 Restart"}
              </button>
            </div>
          </div>
        </div>

        {/* Section B: Chrome Pool Status */}
        <div className="lg:col-span-1 bg-white rounded-lg shadow-lg p-6 border-l-4 border-purple-500">
          <div className="space-y-4">
            <h2 className="text-xl font-bold text-gray-900">Chrome Pool</h2>

            {/* Health Status */}
            <div className="space-y-3">
              <div className="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                <span className="text-sm font-medium text-gray-700">
                  Health
                </span>
                <span
                  className={`inline-flex items-center gap-1 px-3 py-1 rounded-full text-sm font-semibold ${
                    isChromeHealthy
                      ? "bg-green-100 text-green-800"
                      : "bg-red-100 text-red-800"
                  }`}
                >
                  <span className="text-lg">{isChromeHealthy ? "✅" : "❌"}</span>
                  {isChromeHealthy ? "Healthy" : "Unhealthy"}
                </span>
              </div>

              <div className="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                <span className="text-sm font-medium text-gray-700">
                  Browser State
                </span>
                <span className="inline-flex items-center gap-1 px-3 py-1 rounded-full text-sm font-semibold bg-blue-100 text-blue-800">
                  <span className="text-lg">🌐</span>
                  Active
                </span>
              </div>

              {daemonStatus?.last_operation?.timestamp && (
                <div className="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                  <span className="text-sm font-medium text-gray-700">
                    Last Activity
                  </span>
                  <span className="text-sm text-gray-600">
                    {formatTime(daemonStatus.last_operation.timestamp)}
                  </span>
                </div>
              )}
            </div>

            {/* Restart Button */}
            <button
              onClick={restartChrome}
              disabled={!isRunning || actionInProgress !== null}
              className="w-full px-4 py-2 bg-purple-500 text-white rounded-lg hover:bg-purple-600 disabled:bg-gray-400 transition-colors font-medium mt-4"
              aria-label="Restart Chrome"
            >
              {actionInProgress === "restart-chrome"
                ? "⏳ Restarting..."
                : "🔄 Restart Chrome"}
            </button>
          </div>
        </div>
      </div>

      {/* Section C: Task Queue Stats */}
      <div className="bg-white rounded-lg shadow-lg p-6 border-l-4 border-yellow-500">
        <div className="space-y-4">
          <h2 className="text-xl font-bold text-gray-900">Task Queue</h2>

          {/* Status Badges */}
          <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div className="bg-yellow-50 rounded-lg p-4 border-l-4 border-yellow-500">
              <p className="text-sm text-gray-600">Pending</p>
              <p className="text-2xl font-bold text-yellow-600">
                📋 {queueStats.pending}
              </p>
            </div>
            <div className="bg-blue-50 rounded-lg p-4 border-l-4 border-blue-500">
              <p className="text-sm text-gray-600">Running</p>
              <p className="text-2xl font-bold text-blue-600">
                ▶️ {queueStats.running}
              </p>
            </div>
            <div className="bg-green-50 rounded-lg p-4 border-l-4 border-green-500">
              <p className="text-sm text-gray-600">Completed</p>
              <p className="text-2xl font-bold text-green-600">
                ✅ {queueStats.completed}
              </p>
            </div>
            <div className="bg-red-50 rounded-lg p-4 border-l-4 border-red-500">
              <p className="text-sm text-gray-600">Failed</p>
              <p className="text-2xl font-bold text-red-600">
                ❌ {queueStats.failed}
              </p>
            </div>
          </div>

          {/* Progress Bar */}
          {totalQueue > 0 && (
            <div className="space-y-2">
              <div className="flex justify-between items-center">
                <span className="text-sm font-medium text-gray-700">
                  Queue Progress
                </span>
                <span className="text-sm text-gray-600">
                  {completedQueue} / {totalQueue}
                </span>
              </div>
              <div className="w-full bg-gray-200 rounded-full h-3 overflow-hidden">
                <div
                  className="bg-gradient-to-r from-blue-500 to-green-500 h-full transition-all duration-300"
                  style={{ width: `${queueProgress}%` }}
                ></div>
              </div>
            </div>
          )}

          {/* Queue Health Indicator */}
          <div className="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
            <span className="text-sm font-medium text-gray-700">
              Queue Health
            </span>
            <span
              className={`inline-flex items-center gap-1 px-3 py-1 rounded-full text-sm font-semibold ${
                queueStats.pending + queueStats.running > 10
                  ? "bg-yellow-100 text-yellow-800"
                  : "bg-green-100 text-green-800"
              }`}
            >
              <span className="text-lg">
                {queueStats.pending + queueStats.running > 10 ? "⚠️" : "✅"}
              </span>
              {queueStats.pending + queueStats.running > 10 ? "High Load" : "Normal"}
            </span>
          </div>
        </div>
      </div>

      {/* Section D: Recent Operations Log */}
      <div className="bg-white rounded-lg shadow-lg p-6 border-l-4 border-indigo-500">
        <div className="space-y-4">
          <h2 className="text-xl font-bold text-gray-900">Recent Operations</h2>

          {/* Operations Table */}
          <div className="overflow-x-auto">
            <table className="w-full text-sm">
              <thead>
                <tr className="border-b-2 border-gray-200">
                  <th className="text-left px-3 py-2 font-semibold text-gray-700">
                    Task Type
                  </th>
                  <th className="text-left px-3 py-2 font-semibold text-gray-700">
                    Status
                  </th>
                  <th className="text-left px-3 py-2 font-semibold text-gray-700">
                    Timestamp
                  </th>
                  <th className="text-right px-3 py-2 font-semibold text-gray-700">
                    Duration
                  </th>
                </tr>
              </thead>
              <tbody>
                {operationLogs.length > 0 ? (
                  operationLogs.map((op, idx) => (
                    <tr
                      key={`${op.task_id}-${idx}`}
                      className="border-b border-gray-100 hover:bg-gray-50 transition-colors"
                      title={op.error || ""}
                    >
                      <td className="px-3 py-3 text-gray-900 font-medium">
                        {op.task_type}
                      </td>
                      <td className="px-3 py-3">
                        <span
                          className={`inline-flex items-center gap-1 px-2 py-1 rounded text-xs font-semibold ${
                            op.success
                              ? "bg-green-100 text-green-800"
                              : "bg-red-100 text-red-800"
                          }`}
                        >
                          <span className="text-lg">
                            {op.success ? "✅" : "❌"}
                          </span>
                          {op.success ? "Success" : "Failed"}
                        </span>
                      </td>
                      <td className="px-3 py-3 text-gray-600">
                        {formatTime(op.timestamp)}
                      </td>
                      <td className="px-3 py-3 text-right text-gray-600">
                        {op.duration_ms ? `${op.duration_ms}ms` : "—"}
                      </td>
                    </tr>
                  ))
                ) : (
                  <tr>
                    <td colSpan={4} className="px-3 py-6 text-center text-gray-500">
                      No operations yet
                    </td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>

          {/* Auto-scroll anchor */}
          <div ref={operationsEndRef} />

          {/* Operation details hint */}
          {operationLogs.length > 0 && operationLogs.some((op) => op.error) && (
            <p className="text-xs text-gray-500 mt-2">
              💡 Tip: Hover over failed operations to see error details
            </p>
          )}
        </div>
      </div>

      {/* Footer Info */}
      <div className="text-center text-sm text-gray-500 mt-8">
        <p>
          Connected to X-Daemon on localhost:8765 • Polling every 2 seconds •
          Last {operationLogs.length} operations
        </p>
      </div>
    </div>
  );
};

export default XDaemonMonitor;
