# ==============================================
# XHive Worker - Environment Configuration
# Kopyalayın: .env.example -> .env
# Gerçek değerlerinizi doldurun
# ==============================================

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# === Telegram API (gelişmiş özellikler için) ===
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+90xxxxxxxxxx

# === Gemini AI ===
GEMINI_API_KEY=your_gemini_api_key_here

# === OpenAI (isteğe bağlı) ===
OPENAI_API_KEY=

# === Twitter / X API v2 ===
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret
TWITTER_BEARER_TOKEN=your_bearer_token

# === ProductHunt API ===
PRODUCTHUNT_API_TOKEN=your_producthunt_api_token_here
PRODUCTHUNT_API_KEY=your_producthunt_api_key_here
PRODUCTHUNT_API_SECRET=your_producthunt_api_secret_here

# === Reddit API ===
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=XHive Bot v1.0

# === Uygulama Ayarları ===
ENVIRONMENT=production
LOG_LEVEL=INFO
CHROME_HEADLESS=True

# === Güvenlik Limitleri ===
MAX_TWEETS_PER_DAY=10
MAX_LIKES_PER_DAY=50
MAX_FOLLOWS_PER_DAY=20

# === Dosya Yolları (otomatik - değiştirmeyin) ===
# Boş bırakın — config.py AppData'dan otomatik çözer
# LOCK_PATH=
# DATA_PATH=
# BROWSER_DATA_DIR=
# COOKIE_PATH=
